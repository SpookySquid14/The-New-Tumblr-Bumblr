	quests: [
		{
			description: [
				"Howdy! You can call be the Quartermaster! I am fluent in all things storage- well maybe not all things, there are some wizard's an' shit that can do the same... but if it's made out of wood, it's my specialty!"
				""
				""
				"First, Just make a chest to toss yer shit."
			]
			id: "25B20970F2E51E30"
			rewards: [
