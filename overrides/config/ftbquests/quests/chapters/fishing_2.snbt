					type: "item"
				}
			]
			subtitle: "Craft an iron fishing rod"
			tasks: [{
				id: "34C17B8723B8253F"
				item: {
					Count: 1
					id: "aquaculture:iron_fishing_rod"
					tag: {
						Damage: 0
					}
				}
				match_nbt: true
				type: "item"
				weak_nbt_match: true
			}]
			title: "Taking things to the next level"
			x: -3.5d
			y: -5.5d
		}
		{
			dependencies: ["3C88203BB36909F6"]
			description: ["&o&6The Tackle Box&r is your key to truly customizing and improving your fishing experience. Hopefully you still have some of the iron and algae from the last quest's rewards, but if not, it shouldn't be too hard to find substitutes."]
			hide_until_deps_visible: true
			id: "7D0EE07823EB90B1"
			rewards: [
				{
					amount: 100L
					currency: "eternalcurrencies:ancientcoins"
					id: "382EB588497A76B6"
					ignore_reward_blocking: true
					type: "eternalcurrencies:currency"
				}
				{
					id: "756D7ACF7FE4D932"
					item: "aquaculture:fishing_line"
					type: "item"
				}
				{
					id: "6F4B72F5EE05019E"
					item: "aquaculture:bobber"
					type: "item"
				}
			]
			subtitle: "Craft a tackle box"
			tasks: [{
				id: "6EA54909637A81DE"
				item: "aquaculture:tackle_box"
				type: "item"
			}]
			title: "Getting into the deep end."
			x: -3.5d
			y: -4.5d
		}
		{
			dependencies: ["7D0EE07823EB90B1"]
			description: [
				"{image:modpack:textures/tackle-box-menu.png width:100 height:100 align:center}"
				"The tackle box has a variety of functions, the first being simple storage of your fishing related items, such as hooks, bobbers, and bait. You can freely pick up and place down your tackle box, allowing for ease of transportation."
				"The primary function of the tackle box, however, is the ability to modify your fishing rod by equipping bobbers, fishing line, hooks, and bait. In the last quest, you were given a simple bobber and fishing line. These items are purely cosmetic, and can be dyed to give your fishing rod a little more personality. You will however find other bobbers in your travels that offer unique effects and bonuses."
			]
			hide_until_deps_visible: true
			id: "74B1B18C1BBC9EFF"
			rewards: [{
				amount: 120L
				currency: "eternalcurrencies:ancientcoins"
				id: "3020427AE22CE73B"
				ignore_reward_blocking: true
				type: "eternalcurrencies:currency"
			}]
			subtitle: "Use a tackle box to customize your fishing rod"
			tasks: [{
				block: "aquaculture:tackle_box"
				block_type: 0
				checkItem: false
				id: "483B19ECD7E64F4E"
				isItemInteraction: false
				type: "questsadditions:use"
				value: 1L
			}]
			title: "Let's get custom!"
			x: -3.5d
			y: -3.5d
		}
		{
			dependencies: ["74B1B18C1BBC9EFF"]
			description: [
				"If you're wanting to get better odds in your fishing endeavors, then let me introduce you to &o&6bait&r. And not the online kind!"
				"Bait comes in three forms: &oworms, leeches, and minnows&r. We'll get into the latter two in a bit, but first let's get some worms. For that, you'll need to make a &o&6worm farm&r."
				"{image:modpack:textures/worm-farm.png width:156 height:90 align:center}"
			]
			hide_until_deps_visible: true
			id: "12248D0134A1B320"
			rewards: [{
				amount: 100L
				currency: "eternalcurrencies:ancientcoins"
				id: "690F6554F0C640F9"
				ignore_reward_blocking: true
				type: "eternalcurrencies:currency"
			}]
			tasks: [{
				id: "347860BDF8D6B2E5"
				item: "aquaculture:worm_farm"
				type: "item"
			}]
			title: "Squirmy Wormy"
			x: -3.5d
			y: -2.5d
		}
		{
			dependencies: ["12248D0134A1B320"]
			description: [
				"You've got a worm farm. Great! Now you just need to get some worms. This is an easy process. Simply use the farm like you would a composter. &6&oBy putting seeds, vegetables, and other compostable items inside, your farm will fill up with worms.&r Once filled, right clicking will let you harvest them."
				"PS: Unlike a composter, you don't need to fill the Worm Farm fully. Any amount of filling will produce a single worm."
			]
			hide_until_deps_visible: true
			id: "1F3B5DCD1B92F326"
			rewards: [{
				amount: 100L
				currency: "eternalcurrencies:ancientcoins"
				id: "081C083BCA735E45"
				ignore_reward_blocking: true
				type: "eternalcurrencies:currency"
			}]
			tasks: [{
				count: 16L
				id: "7DFA184759B1F283"
				item: {
					Count: 16
					id: "aquaculture:worm"
					tag: {
						Damage: 0
					}
				}
				type: "item"
			}]
			title: "Can't Worm Out of This One"
			x: -3.0d
			y: -1.5d
		}
		{
			dependencies: ["1F3B5DCD1B92F326"]
			description: ["The second of the three baits, and the first to be caught in the wild, is the humble leech. These tiny blood suckers can be caught in &6&oswamp biomes&r, and prove more effective than worms."]
			hide_until_deps_visible: true
