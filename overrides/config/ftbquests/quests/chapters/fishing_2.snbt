		{
			dependencies: ["593F14E6FF0AACEB"]
			description: ["Now that you've hopefully gotten some experience with basic fishing, it's time to take things up a notch. &oAquaculture 2&r is a mod that adds plenty of new items to fishing, and it all starts with an upgraded rod."]
			hide_dependency_lines: true
			id: "3C88203BB36909F6"
			rewards: [
				{
					amount: 100L
					currency: "eternalcurrencies:ancientcoins"
					id: "3B67D854DDFD26AD"
